# LoanSphere Backend — Environment Variables
# Copy this file to .env and fill in your actual values

# ── MongoDB ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/loansphere?retryWrites=true&w=majority

# ── JWT Auth ───────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# ── Server Port (Render sets this automatically — do NOT hardcode) ─────────
PORT=3000

# ── Email (Brevo SMTP) ─────────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_api_key_here

# ── Frontend URL (your Vercel URL — used for CORS) ─────────────────────────
FRONTEND_URL=https://your-app-name.vercel.app

# ── Razorpay (optional — for live payments) ────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
